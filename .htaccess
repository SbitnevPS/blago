RewriteEngine On
RewriteBase /

# Если файл или папка существует — отдаём напрямую
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Всё остальное — в index.php (роутер)
RewriteRule ^ index.php [L,QSA]

# 🔒 Закрываем доступ к конфигам и служебным файлам
<FilesMatch "^(config\.php|database\.sql|composer\.json|composer\.lock|\.env|\.git)">
    Require all denied
</FilesMatch>

# ❌ Отключаем листинг директорий
Options -Indexes