RewriteEngine On

# Serve existing files/directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Front-controller
RewriteRule ^ index.php [L,QSA]

# Deny direct access to sensitive files
<FilesMatch "^(config\.php|database\.sql|composer\.json|composer\.lock|\.env)$">
    Require all denied
</FilesMatch>

# Deny access to VCS metadata
RedirectMatch 403 /\.git

# Disable directory listing (without Options directives)
IndexIgnore *

<FilesMatch "\.local\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

RewriteRule ^storage/private/ - [F,L,NC]
